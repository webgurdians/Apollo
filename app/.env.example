# ── Frontend (set in Vercel dashboard) ─────────────────────────
# VITE_API_URL=           # Railway backend URL (e.g. https://your-app.up.railway.app)

# ── Backend (set in Railway dashboard) ─────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)
DATABASE_URL=             # SQLite file path (default: sqlite.db)
ALLOWED_ORIGINS=          # Comma-separated frontend URLs (e.g. https://capollo.co.in)

# ── Payments ──────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=    # Razorpay test/live key ID (e.g. rzp_test_xxx)
RAZORPAY_KEY_SECRET=     # Razorpay secret (server-side only)

# ── Report File Storage (S3 or Cloudflare R2) ─────────────────
S3_BUCKET=                # Bucket name (e.g. apollo-reports)
S3_PUBLIC_URL=            # Public base URL (e.g. https://pub-xxxx.r2.dev)
S3_REGION=                # Region (default: auto for R2; e.g. us-east-1 for AWS)
S3_ACCESS_KEY_ID=         # Access key ID
S3_SECRET_ACCESS_KEY=     # Secret access key
